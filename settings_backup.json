// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // AI THING
  // "server_url": "http://localhost:8080",
  "context_servers": {
    "mcp-server-sequential-thinking": {
      "enabled": false,
      "remote": false,
      "settings": {}
    }
  },
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "prettier": {},
  "agent_buffer_font_size": 16.0,
  "edit_predictions": {
    "provider": "codestral",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null,
    },
    "enabled_in_text_threads": false,
  },
  "show_edit_predictions": true,
  "terminal": {
    "shell": {
      "program": "zsh",
    },
  },
  "agent": {
    "dock": "right",
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
    },
    "always_allow_tool_actions": true,
    "default_profile": "ask",
    "default_model": {
      "enable_thinking": true,
      "provider": "google",
      "model": "gemini-2.5-flash-lite",
    },
    "default_width": 360,
  },
  // THEME
  "icon_theme": "Bearded Icons",
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": false,
  },
  // UI (Font)
  "agent_ui_font_size": 20,
  "ui_font_family": "Roboto Flex",
  "ui_font_size": 18,
  "ui_font_weight": 400,
  "ui_font_fallbacks": [".ZedMono"],
  "buffer_font_family": "Monaspace Neon Frozen",
  "buffer_font_weight": 500,
  "buffer_font_fallbacks": [
    "Monaspace Neon",
    "JetBrainsMonoNL Nerd Font Mono",
    "Fira Code",
    "Noto Sans Mono",
  ],
  "buffer_font_size": 18.0,
  "buffer_line_height": { "custom": 1.6 },
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "cv01": 0,
  },
  "tabs": { "file_icons": true },
  "theme": {
    "mode": "dark",
    "light": "macOS Classic Light",
    "dark": "Proto Monokai V (Soft)",
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.idea",
  ],
  "indent_guides": {
    "active_line_width": 2,
  },
  "tab_size": 2,
  // "terminal": {
  //   "font_size": 18,
  //   "button": true,
  //   "font_family": "Monaspace Neon Frozen"
  // },
  "project_panel": {
    "dock": "left",
    "indent_size": 12,
    "indent_guides": { "show": "never" },
    "entry_spacing": "standard",
  },
  "inlay_hints": {
    "show_parameter_hints": false,
    "show_type_hints": true,
    "show_other_hints": false,
    "show_background": true,
  },
  "languages": {
    "JSONC": {
      "show_edit_predictions": false,
    },
    "JavaScript": {
      "code_actions_on_format": {
        // "source.fixAll.biome": true, // for biome
        // "source.organizeImports.biome": true // for biome
      },
      "prettier": {
        "allowed": true,
        "singleQuote": true,
      },
      "formatter": "language_server", // Formatter for deno
      // Formatter for biome
      // "formatter": {
      //   "language_server": {
      //     "name": "biome"
      //   }
      // }
    },
    "TypeScript": {
      "show_edit_predictions": true,
      "code_actions_on_format": {
        // "source.fixAll.biome": true, // for biome
        // "source.organizeImports.biome": true // for biome
      },
      "prettier": {
        "allowed": true,
        "singleQuote": true,
      },
      // Disable language_servers and formatter if use environment other than Deno
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
      // Formatter for biome
      // "formatter": {
      // "language_server": { "name": "biome" }
      // }
    },
    "TSX": {
      "code_actions_on_format": {
        // "source.fixAll.biome": true,
        // "source.organizeImports.biome": true
      },
      "prettier": {
        "allowed": true,
        "singleQuote": true,
      },
      "formatter": "language_server",
      // Formatter for biome
      // "formatter": {
      // "language_server": { "name": "biome" }
      // }
    },
    "Go": {
      "show_edit_predictions": true,
      "format_on_save": "on",
      "formatter": "auto",
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "vtsls": {
          "experimental": {
            "maxInlayHintLength": 15,
          },
        },
      },
    },
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
        },
      },
    },
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [
            {
              "fileMatch": ["deno.json", "deno.jsonc"],
              "url": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
            },
            {
              "fileMatch": ["package.json"],
              "url": "https://www.schemastore.org/package",
            },
          ],
        },
      },
    },
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "git_hosting_providers": [
    {
      "provider": "github",
      "base_url": "github.com/irpekek",
      "name": "Personal Github",
    },
  ],
}
